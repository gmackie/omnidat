{
  "name": "@omnidat/operator-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./omnidat": {
      "types": "./dist/omnidat.d.ts",
      "default": "./src/omnidat.ts"
    },
    "./vt100": {
      "types": "./dist/vt100.d.ts",
      "default": "./src/vt100.ts"
    },
    "./terminal": {
      "types": "./dist/omnidat-terminal.d.ts",
      "default": "./src/omnidat-terminal.ts"
    },
    "./attract": {
      "types": "./dist/omnidat-attract.d.ts",
      "default": "./src/omnidat-attract.ts"
    },
    "./profiles": {
      "types": "./dist/terminal-profiles.d.ts",
      "default": "./src/terminal-profiles.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "license": "MIT",
  "scripts": {
    "build": "rm -rf dist && tsup src/index.ts src/omnidat.ts src/vt100.ts src/omnidat-terminal.ts src/omnidat-attract.ts src/terminal-profiles.ts --format esm && tsc -p tsconfig.build.json",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsup src/index.ts src/omnidat.ts src/vt100.ts src/omnidat-terminal.ts src/omnidat-attract.ts src/terminal-profiles.ts --format esm --watch --dts",
    "format": "biome check .",
    "lint": "oxlint .",
    "test": "vitest run src/__tests__/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@omnidat/trpc-client": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@omnidat/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "oxlint": "catalog:",
    "tsup": "^8.5.1",
    "typescript": "catalog:",
    "vitest": "^4.1.0"
  }
}
