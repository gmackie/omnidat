{
  "name": "@omnidat/realtime",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "biome check .",
    "lint": "oxlint .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@omnidat/config": "workspace:*",
    "@omnidat/logging": "workspace:*",
    "bullmq": "^5.52.2",
    "ioredis": "^5.6.1"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@omnidat/tsconfig": "workspace:*",
    "oxlint": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.1.0"
  }
}
