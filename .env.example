# OMNIDAT V1 shared infrastructure

# V1 intentionally shares the FryOS local Postgres service and database.
# Keep OMNIDAT tables in their own schema so FryOS production/order state stays
# separate from Packet Clearing, Radio PAD, activity, and queue records.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gmacko_dev"
OMNIDAT_DB_SCHEMA="omnidat"

# Local app runtime
OMNIDAT_HOST="127.0.0.1"
OMNIDAT_PORT="8828"

# Prototype runtime paths used by the current Python harness until the
# create-gmacko-app web app owns persistence.
OMNIDAT_DATA_DIR="data"
OMNIDAT_BUILD_DIR="build"

# OMNIDAT Matrix bridge (the omnichat repo's @omnidat/bridge internal API).
# Used by tools/omnidat_packet.py, tools/omnidat_mesh_gateway.py, and the
# telnet PAD. The secret must match the bridge's INTERNAL_API_SECRET.
OMNIDAT_BRIDGE_URL="http://127.0.0.1:8090"
OMNIDAT_BRIDGE_SECRET=""
