# Authentik deployment secrets for auth.omnidat.cc. Copy to .env and fill in.
# .env is gitignored; never commit real values.

# Postgres (Authentik's own database — not the shared FryOS Postgres).
PG_USER=authentik
PG_DB=authentik
# openssl rand -base64 36
PG_PASS=

# Authentik server secret key (session/crypto). Generate once:
#   openssl rand -base64 60 | tr -d '\n'
AUTHENTIK_SECRET_KEY=

# Pin a specific Authentik release rather than a floating tag in production.
AUTHENTIK_TAG=2026.2

# Local ports the server listens on (Cloudflare Tunnel / reverse proxy targets).
AUTHENTIK_PORT=9000
AUTHENTIK_PORT_TLS=9443
