#!/bin/sh
set -eu

if [ "${LEFTHOOK:-1}" = "0" ]; then
  exit 0
fi

run_hook() {
  hook_name="$1"
  shift || true

  case "$hook_name" in
    prepare-commit-msg)
      exit 0
      ;;
    pre-commit)
      npm test --silent
      ./scripts/validate-data
      ;;
    *)
      echo "lefthook: no commands configured for $hook_name"
      ;;
  esac
}

if [ "${1:-}" = "run" ]; then
  shift
fi

if [ "$#" -eq 0 ]; then
  echo "usage: scripts/lefthook run <hook-name>" >&2
  exit 2
fi

run_hook "$@"
