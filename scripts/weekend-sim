#!/usr/bin/env sh
set -eu

runtime_dir="${OMNIDAT_WEEKEND_DIR:-build/weekend-sim}"
campers="${OMNIDAT_WEEKEND_CAMPERS:-1000}"
load_factor="${OMNIDAT_WEEKEND_LOAD_FACTOR:-1.0}"
rm -rf "$runtime_dir"
mkdir -p "$runtime_dir"

# The sim runs on a sim field kit. Set OMNIDAT_SYNC_TARGET (and
# OMNIDAT_SYNC_TOKEN) to soak-test the sync path against a gmacko target;
# unset, it runs journal-local with no network access.
# Use OMNIDAT_WEEKEND_LOAD_FACTOR >1.0 for saturation/load testing (triggers congestion).
python3 -m tools.omnidat_weekend --runtime-dir "$runtime_dir" --campers "$campers" --load-factor "$load_factor"
